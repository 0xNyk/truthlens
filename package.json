{
  "name": "truthlens",
  "version": "0.1.0",
  "private": true,
  "description": "AI content authenticity detector \u2014 browser extension",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @truthlens/extension dev",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/core packages/ui"
  },
  "keywords": [
    "ai-detection",
    "c2pa",
    "deepfake",
    "browser-extension"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "devDependencies": {
    "dotenv": "^8.2.0",
    "node-fetch": "^3.3.2",
    "oxlint": "^0.16.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
